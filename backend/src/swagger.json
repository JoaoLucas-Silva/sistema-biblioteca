{
  "openapi": "3.0.0",
  "info": {
    "title": "API - Sistema de Biblioteca",
    "version": "1.0.0",
    "description": "Documentação da API RESTful para o projeto de Engenharia de Software."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "senha"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@biblioteca.com"
          },
          "senha": {
            "type": "string",
            "example": "123456"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "usuario": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "email": {
                "type": "string"
              },
              "perfil": {
                "type": "string",
                "enum": ["ADMIN", "BIBLIOTECARIO", "LEITOR"]
              }
            }
          }
        }
      },
      "UsuarioCreateRequest": {
        "type": "object",
        "required": ["email", "senha", "perfil"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "funcionario@biblioteca.com"
          },
          "senha": {
            "type": "string",
            "example": "123456"
          },
          "perfil": {
            "type": "string",
            "enum": ["ADMIN", "BIBLIOTECARIO"],
            "example": "BIBLIOTECARIO"
          }
        }
      },
      "LeitorCreateRequest": {
        "type": "object",
        "required": ["email", "senha", "nome", "cpf_ra"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "leitor@biblioteca.com"
          },
          "senha": {
            "type": "string",
            "example": "123456"
          },
          "nome": {
            "type": "string",
            "example": "Maria Silva"
          },
          "cpf_ra": {
            "type": "string",
            "example": "12345678900"
          },
          "telefone": {
            "type": "string",
            "example": "(11) 99999-9999"
          },
          "endereco": {
            "type": "string",
            "example": "Rua Central, 123"
          }
        }
      },
      "LeitorUpdateRequest": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "cpf_ra": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "endereco": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["ATIVO", "INATIVO"]
          }
        }
      },
      "LivroCreateRequest": {
        "type": "object",
        "required": ["titulo", "autor"],
        "properties": {
          "titulo": {
            "type": "string",
            "example": "Clean Code"
          },
          "autor": {
            "type": "string",
            "example": "Robert C. Martin"
          },
          "editora": {
            "type": "string",
            "example": "Prentice Hall"
          },
          "ano_publicacao": {
            "type": "integer",
            "example": 2008
          },
          "categoria": {
            "type": "string",
            "example": "Programação"
          },
          "isbn": {
            "type": "string",
            "example": "9780132350884"
          },
          "quantidade_total": {
            "type": "integer",
            "example": 5
          },
          "quantidade_disponivel": {
            "type": "integer",
            "example": 5
          },
          "status": {
            "type": "string",
            "enum": ["DISPONIVEL", "INDISPONIVEL"]
          },
          "capa_url": {
            "type": "string",
            "example": "https://exemplo.com/capa.jpg"
          }
        }
      },
      "LivroUpdateRequest": {
        "type": "object",
        "properties": {
          "titulo": {
            "type": "string"
          },
          "autor": {
            "type": "string"
          },
          "editora": {
            "type": "string"
          },
          "ano_publicacao": {
            "type": "integer"
          },
          "categoria": {
            "type": "string"
          },
          "isbn": {
            "type": "string"
          },
          "quantidade_total": {
            "type": "integer"
          },
          "quantidade_disponivel": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["DISPONIVEL", "INDISPONIVEL"]
          },
          "capa_url": {
            "type": "string"
          }
        }
      },
      "EmprestimoCreateRequest": {
        "type": "object",
        "required": ["leitor_id", "livros_ids"],
        "properties": {
          "leitor_id": {
            "type": "string",
            "format": "uuid",
            "example": "11111111-1111-1111-1111-111111111111"
          },
          "livros_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "example": ["22222222-2222-2222-2222-222222222222"]
          }
        }
      },
      "EmprestimoResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "leitor_id": {
            "type": "string",
            "format": "uuid"
          },
          "data_emprestimo": {
            "type": "string",
            "format": "date-time"
          },
          "data_prevista_devolucao": {
            "type": "string",
            "format": "date-time"
          },
          "data_real_devolucao": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["EM_ABERTO", "DEVOLVIDO", "ATRASADO"]
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Autenticar usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "404": {
            "description": "Usuário não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Senha inválida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/usuarios": {
      "post": {
        "tags": ["Usuários"],
        "summary": "Cadastrar usuário",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UsuarioCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado com sucesso"
          },
          "400": {
            "description": "Erro de validação",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Perfil insuficiente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/leitores": {
      "get": {
        "tags": ["Leitores"],
        "summary": "Listar leitores",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "nome",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro parcial por nome"
          },
          {
            "name": "cpf_ra",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro exato por CPF ou RA"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de leitores"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      },
      "post": {
        "tags": ["Leitores"],
        "summary": "Cadastrar leitor",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeitorCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Leitor criado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      }
    },
    "/api/leitores/{id}" : {
      "get": {
        "tags": ["Leitores"],
        "summary": "Buscar leitor por ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Leitor encontrado"
          },
          "404": {
            "description": "Leitor não encontrado"
          }
        }
      },
      "put": {
        "tags": ["Leitores"],
        "summary": "Atualizar leitor",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LeitorUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Leitor atualizado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          },
          "500": {
            "description": "Erro interno"
          }
        }
      },
      "delete": {
        "tags": ["Leitores"],
        "summary": "Excluir leitor",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Leitor excluído com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      }
    },
    "/api/livros": {
      "get": {
        "tags": ["Livros"],
        "summary": "Listar livros",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "titulo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro parcial por título"
          },
          {
            "name": "autor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro parcial por autor"
          },
          {
            "name": "categoria",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro parcial por categoria"
          },
          {
            "name": "isbn",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtro exato por ISBN"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["DISPONIVEL", "INDISPONIVEL"]
            },
            "description": "Filtro exato por status"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de livros"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "tags": ["Livros"],
        "summary": "Cadastrar livro",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LivroCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Livro criado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      }
    },
    "/api/livros/{id}": {
      "get": {
        "tags": ["Livros"],
        "summary": "Buscar livro por ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Livro encontrado"
          },
          "404": {
            "description": "Livro não encontrado"
          }
        }
      },
      "put": {
        "tags": ["Livros"],
        "summary": "Atualizar livro",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LivroUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Livro atualizado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      },
      "delete": {
        "tags": ["Livros"],
        "summary": "Excluir livro",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Livro excluído com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      }
    },
    "/api/emprestimos": {
      "get": {
        "tags": ["Empréstimos"],
        "summary": "Listar empréstimos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["EM_ABERTO", "DEVOLVIDO", "ATRASADO"]
            },
            "description": "Filtro exato por status"
          },
          {
            "name": "data_emprestimo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filtro exato por data do empréstimo"
          },
          {
            "name": "leitor_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Filtro exato por leitor"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de empréstimos"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "tags": ["Empréstimos"],
        "summary": "Registrar empréstimo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmprestimoCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Empréstimo registrado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          }
        }
      }
    },
    "/api/emprestimos/{id}/devolucao": {
      "put": {
        "tags": ["Empréstimos"],
        "summary": "Registrar devolução do empréstimo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Devolução registrada com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Perfil insuficiente"
          },
          "500": {
            "description": "Erro interno"
          }
        }
      }
    },
    "/api/emprestimos/meus": {
      "get": {
        "tags": ["Empréstimos"],
        "summary": "Listar meus empréstimos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de empréstimos do usuário autenticado"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    }
  }
}
